async function buildBookingOpts(){
  const p=await stGet('profile:'+currentOrderReg);
  if(!p)return;
  const pr=p.prefs||[];
  const tipOpts=pr.filter(k=>['tip2','tip5','tip10','book2','book5','book10'].includes(k));
  const sec=document.getElementById('oBookingSection');
  if(!tipOpts.length){sec.style.display='none';return;}
  sec.style.display='block';
  document.getElementById('oBookingOpts').innerHTML=tipOpts.map(k=>{
    const labels={tip2:'+2€ идване',tip5:'+5€ идване',tip10:'+10€ идване',book2:'Букинг +2€',book5:'Букинг +5€',book10:'Букинг +10€'};
    const prices={tip2:2,tip5:5,tip10:10,book2:2,book5:5,book10:10};
    return `<div class="book-opt" data-k="${k}" data-price="${prices[k]}" onclick="selectBooking(this)">
      <div class="bo-price">+${prices[k]}€</div>
      <div class="bo-label">${labels[k]}</div>
    </div>`;
  }).join('');
}

function selectBooking(el){
  document.querySelectorAll('.book-opt').forEach(x=>x.classList.remove('on'));
  if(selectedBooking===el.dataset.k){selectedBooking=null;}
  else{el.classList.add('on');selectedBooking=el.dataset.k;}
}

async function submitOrder(){
  const from=document.getElementById('oFrom').value.trim();
  const to=document.getElementById('oTo').value.trim();
  const note=document.getElementById('oNote').value.trim();
  if(!from||!to){alert('Въведи откъде и накъде.');return;}

  const bookingPrices={tip2:2,tip5:5,tip10:10,book2:2,book5:5,book10:10};
  const bookingFee=selectedBooking?bookingPrices[selectedBooking]||0:0;

  const orderId='ord_'+Date.now();
  currentOrderId=orderId;
  const order={
    id:orderId,reg:currentOrderReg,
    from,to,note,bookingFee,selectedBooking,
    status:'pending',// pending → confirmed → completed → cancelled
    price:null,
    createdAt:new Date().toISOString()
  };
  await stSet('order:'+orderId,order);
  // Add to driver's request queue
  const drvOrders=await stGet('drvOrders:'+currentOrderReg)||[];
  drvOrders.unshift(orderId);
  await stSet('drvOrders:'+currentOrderReg,drvOrders);

  document.getElementById('orderStepA').style.display='none';
  document.getElementById('orderStepB').style.display='flex';
  document.getElementById('oWaitInfo').innerHTML=`🚕 <strong>${currentOrderReg}</strong><br>📍 ${esc(from)} → ${esc(to)}${note?'<br>📝 '+esc(note):''}${bookingFee?'<br>💶 Добавка: +'+bookingFee+'€':''}`;
}

async function checkOrderPrice(){
  if(!currentOrderId)return;
  const btn=document.getElementById('checkPriceBtn');
  btn.textContent='⏳ Проверяване…';btn.disabled=true;
  const order=await stGet('order:'+currentOrderId);
  if(order&&order.status==='confirmed'&&order.price){
    showPaymentStep(order);
  } else {
    alert('Шофьорът все още не е потвърдил. Опитай след малко.');
  }
  btn.textContent='🔄 Провери цена';btn.disabled=false;
}

function showPaymentStep(order){
  document.getElementById('orderStepB').style.display='none';
  document.getElementById('orderStepC').style.display='flex';
  const pct=admSettings.commPct||COMM_PCT;
  const total=parseFloat(order.price)+(order.bookingFee||0);
  const comm=(total*pct/100).toFixed(2);
  document.getElementById('oPriceCalc').innerHTML=`
    <div class="price-row"><span class="lbl">Цена на курса</span><span class="val">${order.price}€</span></div>
    ${order.bookingFee?`<div class="price-row"><span class="lbl">${order.selectedBooking?.startsWith('book')?'Букинг':'Идване от далеч'}</span><span class="val">+${order.bookingFee}€</span></div>`:''}
    <hr class="divider"/>
    <div class="price-row total"><span class="lbl" style="font-weight:900">Общо за плащане</span><span class="val">${total.toFixed(2)}€</span></div>
    <div class="price-row commission"><span class="lbl">Платете директно на шофьора в колата</span></div>`;
  // Driver contact
  const drvContact=document.getElementById('oDriverContact');
  if(order.driverPhone){
    drvContact.style.display='block';
    drvContact.innerHTML=`📱 Шофьорът е на линия: <strong>${esc(order.driverPhone)}</strong>`;
  }
}

async function cancelOrder(){
  if(!currentOrderId)return;
  const order=await stGet('order:'+currentOrderId);
  if(order){order.status='cancelled';await stSet('order:'+currentOrderId,order);}
  closeModal();
}

function backToProfile(){
