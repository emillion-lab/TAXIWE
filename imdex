}

function buildBrandSelects(){
  const sel=document.getElementById('fCarBrand');
  Object.keys(CAR_BRANDS).forEach(b=>{const o=document.createElement('option');o.value=b;o.textContent=b;sel.appendChild(o);});
}

function updateModelList(){
  const brand=document.getElementById('fCarBrand').value;
  const models=CAR_BRANDS[brand]||[];
  const inp=document.getElementById('fCarModel');
  if(models.length){
    // suggest models as datalist
    let dl=document.getElementById('modelDL');
    if(!dl){dl=document.createElement('datalist');dl.id='modelDL';document.body.appendChild(dl);}
    dl.innerHTML=models.map(m=>`<option value="${m}">`).join('');
    inp.setAttribute('list','modelDL');
  } else {
    inp.removeAttribute('list');
  }
}

function buildDistrictFilter(){
  const sel=document.getElementById('distFlt');
  DISTRICTS.forEach(d=>{const o=document.createElement('option');o.value=d;o.textContent=d;sel.appendChild(o);});
}

async function loadRegistry(){
  try{
    const r=await fetch(REGISTRY_URL);
    if(!r.ok)return;
    const data=await r.json();
    const list=Array.isArray(data)?data:(data.data||data.items||[]);
    list.forEach(item=>{
      const op=(item.operatorName||'').trim();
      const vl=item.taxiLicensesVehiclesDrivers||item.vehicles||[];
      vl.forEach(vd=>{
        const v=vd.taxiLicenseVehicle||vd.vehicle||vd||{};
        const reg=nReg(v.registerNumber||v.regNumber||'');
        if(reg&&!registry.has(reg)) registry.set(reg,{op,model:(v.markAndModel||v.model||'—').trim()});
      });
    });
    // Build brand filter from registry
    buildBrandFilter();
  }catch(e){console.warn('Registry:',e.message);}
}

function buildBrandFilter(){
  const sel=document.getElementById('brandFlt');
  Object.keys(CAR_BRANDS).forEach(b=>{const o=document.createElement('option');o.value=b;o.textContent=b;sel.appendChild(o);});
}

function nReg(s){return(s||'').toUpperCase().replace(/\s+/g,'').trim();}

