async function openModal(reg,directOrder=false){
  currentOrderReg=reg;
  selectedBooking=null;
  const p=await stGet('profile:'+reg);
  if(!p)return;

  // Fill profile
  document.getElementById('mPlate').textContent=p.reg;
  document.getElementById('mOp').textContent=p.op||'';
  const carInfo=[p.carBrand,p.carModel,p.carYear].filter(Boolean).join(' ');
  document.getElementById('mCarInfo').textContent=carInfo||'';
  document.getElementById('mBio').textContent=p.bio||'Няма описание.';
  document.getElementById('mOnline').innerHTML=p.online?'<span class="spill sp-on">🟢 Онлайн</span>':'<span class="spill sp-off">Офлайн</span>';

  const carCom=document.getElementById('mCarComfortRow');
  if(p.carComfort){document.getElementById('mCarComfort').textContent=p.carComfort;carCom.style.display='flex';}
  else carCom.style.display='none';

  const pr=p.prefs||[];
  const tags=pr.filter(k=>PTAGS[k]&&!['tip2','tip5','tip10','book2','book5','book10'].includes(k))
    .map(k=>`<span class="tag ${PTAGS[k].c}">${PTAGS[k].l}</span>`).join('');
  document.getElementById('mTags').innerHTML=tags||'<span style="color:var(--mu);font-size:12px">Не са посочени</span>';
  document.getElementById('mHours').textContent=(p.hours||[]).join(' · ')||'—';
  document.getElementById('mDist').textContent=(p.districts||[]).join(', ')||'—';
  const phRow=document.getElementById('mPhoneRow');
  if(p.phone){document.getElementById('mPhone').textContent=p.phone;phRow.style.display='flex';}else phRow.style.display='none';

  showModalProfile();
  document.getElementById('overlay').classList.remove('hide');
  if(directOrder)startOrder();
}

