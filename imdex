async function doVerify(){
  const reg=nReg(document.getElementById('vPlate').value);
  const phone=document.getElementById('vPhone').value.trim();
  if(!reg){alert('Въведи рег. номер.');return;}
  if(!phone){alert('Въведи телефон.');return;}
  const btn=document.getElementById('vBtn');
  btn.textContent='…';btn.disabled=true;
  const rEl=document.getElementById('vResult');
  rEl.style.display='block';

  const existing=await stGet('profile:'+reg);
  if(existing){
    if(existing.status==='approved'){rEl.innerHTML=`<div class="vr vr-ok">✅ Одобрен — отваряме профила.</div>`;setTimeout(()=>activateDrv(reg,existing),1000);}
    else if(existing.status==='pending'){rEl.innerHTML=`<div class="vr vr-pend">⏳ Молбата е изпратена — чака одобрение.</div>`;setTimeout(()=>showPending(reg,existing),1000);}
    else{rEl.innerHTML=`<div class="vr vr-err">❌ Молбата е отхвърлена. Свържи се с администратора.</div>`;}
    btn.textContent='Провери и изпрати молба →';btn.disabled=false;return;
  }

  const info=registry.get(reg);
  if(!info){
    rEl.innerHTML=`<div class="vr vr-err">❌ ${reg} не е намерен в официалния регистър. Само активни таксита могат да се регистрират.</div>`;
    btn.textContent='Провери и изпрати молба →';btn.disabled=false;return;
  }

  const profile={reg,op:info.op,model:info.model,phone,status:'pending',prefs:[],hours:[],districts:[],online:false,bio:'',phone,revolut:'',carBrand:'',carModel:'',carYear:'',carComfort:'',submittedAt:new Date().toISOString(),updatedAt:new Date().toISOString()};
  await stSet('profile:'+reg,profile);
  await checkAdmDot();
  rEl.innerHTML=`<div class="vr vr-ok">✅ ${reg} намерен — ${info.op}. Молбата е изпратена!</div>`;
  setTimeout(()=>showPending(reg,profile),1200);
  btn.textContent='Провери и изпрати молба →';btn.disabled=false;
}

