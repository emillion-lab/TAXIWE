/* ── Driver requests ── */
async function renderDrvRequests(){
  if(!drvReg)return;
  const orderIds=await stGet('drvOrders:'+drvReg)||[];
  const sect=document.getElementById('drvRequestsSection');
  const cont=document.getElementById('drvRequests');
  if(!orderIds.length){sect.style.display='none';return;}
  const orders=[];
  for(const id of orderIds.slice(0,10)){const o=await stGet('order:'+id);if(o&&o.status!=='cancelled')orders.push(o);}
  const pending=orders.filter(o=>o.status==='pending');
  if(!pending.length&&!orders.filter(o=>o.status==='confirmed').length){sect.style.display='none';return;}
  sect.style.display='block';
  cont.innerHTML=orders.slice(0,5).map(o=>{
    const isPend=o.status==='pending';
    return `<div class="req-card ${isPend?'new-req':''}">
      <div class="req-top">
        <div>
          <div class="req-from">📍 ${esc(o.from)} → ${esc(o.to)}</div>
          ${o.note?`<div class="req-detail">📝 ${esc(o.note)}</div>`:''}
          ${o.bookingFee?`<div class="req-detail">💶 +${o.bookingFee}€ добавка</div>`:''}
          <div class="req-detail">${new Date(o.createdAt).toLocaleTimeString('bg-BG')}</div>
        </div>
        <span class="spill ${isPend?'sp-pend':o.status==='confirmed'?'sp-on':'sp-off'}">${isPend?'⏳ Нова':o.status==='confirmed'?'✅ Потвърдена':'Приключена'}</span>
      </div>
      ${isPend?`
      <div style="display:flex;flex-direction:column;gap:5px">
        <div class="flabel">Въведи цена на курса (€)</div>
        <div style="display:flex;gap:6px">
          <input class="finput" id="price_${o.id}" placeholder="напр. 15" type="number" min="1" style="flex:1"/>
          <button class="btn btn-gr btn-sm" onclick="confirmOrder('${o.id}')">✅ Потвърди</button>
        </div>
        <button class="btn btn-rd btn-xs" onclick="rejectOrder('${o.id}')">Откажи</button>
      </div>`:`<div class="req-detail">💰 Цена: <strong>${o.price||'—'}€</strong>${o.bookingFee?' + '+o.bookingFee+'€ добавка':''}</div>`}
    </div>`;
  }).join('');
}

async function confirmOrder(orderId){
  const price=document.getElementById('price_'+orderId)?.value;
  if(!price||parseFloat(price)<=0){alert('Въведи валидна цена.');return;}
  const order=await stGet('order:'+orderId);
  if(!order)return;
  order.status='confirmed';
  order.price=parseFloat(price).toFixed(2);
  order.driverPhone=drvPr.phone;
  order.confirmedAt=new Date().toISOString();
  await stSet('order:'+orderId,order);
  // Track commission
  const pct=admSettings.commPct||COMM_PCT;
  const total=parseFloat(order.price)+(order.bookingFee||0);
  const comm=(total*pct/100).toFixed(2);
  const commRecord={orderId,reg:drvReg,price:order.price,bookingFee:order.bookingFee||0,total,comm,status:'pending',from:order.from,to:order.to,createdAt:new Date().toISOString()};
  await stSet('comm:'+orderId,commRecord);
  renderDrvRequests();
  renderDrvComm();
}

async function rejectOrder(orderId){
  const order=await stGet('order:'+orderId);
  if(!order)return;
  order.status='cancelled';order.rejectedAt=new Date().toISOString();
  await stSet('order:'+orderId,order);
  renderDrvRequests();
}

async function renderDrvComm(){
  if(!drvReg)return;
  const keys=await stList('comm:');
  const all=[];
  for(const k of keys){const c=await stGet(k);if(c&&c.reg===drvReg)all.push(c);}
  if(!all.length){document.getElementById('drvCommSection').style.display='none';return;}
  document.getElementById('drvCommSection').style.display='block';
  const total=all.reduce((s,c)=>s+parseFloat(c.comm),0);
  const paid=all.filter(c=>c.status==='paid').reduce((s,c)=>s+parseFloat(c.comm),0);
  const pend=total-paid;
  const revLink=admSettings.revolut?`https://revolut.me/${admSettings.revolut.replace('revolut.me/','').replace('https://','')}`:'';
  document.getElementById('drvCommList').innerHTML=all.slice(0,5).map(c=>`
    <div class="comm-item">
      <span>${esc(c.from.split(' ')[0])}→${esc(c.to.split(' ')[0])}</span>
      <div style="display:flex;align-items:center;gap:8px">
        <span class="comm-amount">${c.comm}€</span>
        <span class="comm-status ${c.status==='paid'?'cs-paid':'cs-pend'}">${c.status==='paid'?'Платено':'Дължимо'}</span>
      </div>
    </div>`).join('');
  const commTot=document.getElementById('drvCommTotal');
  commTot.innerHTML=`Дължимо: <strong style="color:var(--y)">${pend.toFixed(2)}€</strong>`;
  if(pend>0&&revLink){
    const amt=pend.toFixed(2);
    commTot.innerHTML+=` &nbsp; <a href="${revLink}?amount=${amt}&currency=EUR&description=TaxiMatch+commission" target="_blank" class="btn btn-sm btn-y" style="display:inline-block;text-decoration:none;margin-top:6px">💳 Плати ${amt}€ комисионна</a>`;
  }
}

async function saveProfile(){
  if(!drvReg)return;
  const btn=document.getElementById('saveBtn');
  btn.textContent='💾 Запазване…';btn.disabled=true;
  const existing=await stGet('profile:'+drvReg)||{};
  const profile={...existing,
    online:drvPr.online,bio:document.getElementById('fBio').value.trim(),
    phone:document.getElementById('fPhone').value.trim(),
    revolut:document.getElementById('fRevolut').value.trim(),
    carBrand:document.getElementById('fCarBrand').value,
    carModel:document.getElementById('fCarModel').value.trim(),
    carYear:document.getElementById('fCarYear').value.trim(),
    carComfort:document.getElementById('fCarComfort').value.trim(),
    prefs:[...drvPr.prefs],hours:[...drvPr.hours],districts:[...drvPr.districts],
    updatedAt:new Date().toISOString()
  };
  await stSet('profile:'+drvReg,profile);
  btn.textContent='💾 Запази профила';btn.disabled=false;
  const msg=document.getElementById('saveMsg');msg.style.display='block';
  setTimeout(()=>msg.style.display='none',2500);
  renderPass();
}

/* ── Toggles ── */
function tP(el){const p=el.dataset.p;drvPr.prefs.has(p)?(drvPr.prefs.delete(p),el.classList.remove('on')):(drvPr.prefs.add(p),el.classList.add('on'));}
function tPex(el,g){(MUTEX_GROUPS[g]||[]).forEach(x=>{drvPr.prefs.delete(x);document.querySelector(`[data-p="${x}"]`)?.classList.remove('on');});drvPr.prefs.add(el.dataset.p);el.classList.add('on');}
function tH(el){const h=el.dataset.h;drvPr.hours.has(h)?(drvPr.hours.delete(h),el.classList.remove('on')):(drvPr.hours.add(h),el.classList.add('on'));}
function tD(el){const d=el.dataset.d;drvPr.districts.has(d)?(drvPr.districts.delete(d),el.classList.remove('on')):(drvPr.districts.add(d),el.classList.add('on'));}
function toggleOnline(){drvPr.online=!drvPr.online;updateToggle();}
function updateToggle(){document.getElementById('togOnline').classList.toggle('on',drvPr.online);}

/* ══════════════════════════════════════════════
   ADMIN
══════════════════════════════════════════════ */
async function checkAdmDot(){
  const keys=await stList('profile:');
  for(const k of keys){const p=await stGet(k);if(p?.status==='pending'){document.getElementById('admDot').style.display='block';return;}}
  document.getElementById('admDot').style.display='none';
}

function admLogin(){
  if(document.getElementById('admPass').value!==ADMIN_PASS){document.getElementById('admPassErr').style.display='block';return;}
  admLoggedIn=true;
  document.getElementById('admLogin').style.display='none';
  document.getElementById('admPanel').style.display='flex';
  document.getElementById('admRevolut').value=admSettings.revolut;
  document.getElementById('admViber').value=admSettings.viber;
  document.getElementById('admComm').value=admSettings.commPct;
  renderAdm();
}

function admLogout(){
  admLoggedIn=false;
  document.getElementById('admPass').value='';
  document.getElementById('admPassErr').style.display='none';
  document.getElementById('admLogin').style.display='block';
  document.getElementById('admPanel').style.display='none';
}

function saveAdmSettings(){
  admSettings={revolut:document.getElementById('admRevolut').value.trim(),viber:document.getElementById('admViber').value.trim(),commPct:parseFloat(document.getElementById('admComm').value)||COMM_PCT};
  localStorage.setItem('admSettings',JSON.stringify(admSettings));
  alert('✓ Запазено.');
}

async function renderAdm(){
  const keys=await stList('profile:');
  const all=[];for(const k of keys){const p=await stGet(k);if(p)all.push(p);}
  const pend=all.filter(p=>p.status==='pending');
  const appr=all.filter(p=>p.status==='approved');
  const rej=all.filter(p=>p.status==='rejected');

  document.getElementById('admStats').innerHTML=[
    {l:'⏳ Чакащи',v:pend.length,c:'var(--y)'},{l:'✅ Одобрени',v:appr.length,c:'var(--gr)'},{l:'❌ Отхвърлени',v:rej.length,c:'var(--rd)'}
  ].map(s=>`<div class="stat-box"><div class="stat-val" style="color:${s.c}">${s.v}</div><div class="stat-lbl">${s.l}</div></div>`).join('');

  const mk=(p,acts)=>`<div class="adm-card ${p.status}">
    <div class="adm-top">
      <div class="adm-info">
        <div class="adm-name"><span class="plate sm">${esc(p.reg)}</span></div>
        <div class="adm-det">${esc(p.op||'')} · ${esc(p.model||'')}</div>
        <div class="adm-det">📱 ${esc(p.phone||'—')}</div>
        ${p.revolut?`<div class="adm-det">💳 ${esc(p.revolut)}</div>`:''}
        <div class="adm-det" style="color:var(--mu2);font-size:10px">${p.submittedAt?new Date(p.submittedAt).toLocaleString('bg-BG'):''}</div>
      </div>
      <span class="spill ${p.status==='pending'?'sp-pend':p.status==='approved'?'sp-on':'sp-rej'}">${p.status==='pending'?'⏳':p.status==='approved'?'✅':'❌'}</span>
    </div>
    ${admSettings.viber&&p.status==='pending'?`<div style="font-size:11px;color:var(--pu);font-weight:700">💜 Поискай документи: ${admSettings.viber}</div>`:''}
    <div class="adm-actions">${acts}</div>
  </div>`;

  document.getElementById('admPending').innerHTML=pend.length?pend.map(p=>mk(p,`<button class="btn btn-gr btn-xs" onclick="admAction('${p.reg}','approved')">✅ Одобри</button><button class="btn btn-rd btn-xs" onclick="admAction('${p.reg}','rejected')">❌ Отхвърли</button>`)).join(''):`<div style="font-size:12px;color:var(--mu);padding:6px">Няма.</div>`;
  document.getElementById('admApproved').innerHTML=appr.length?appr.map(p=>mk(p,`<button class="btn btn-ghost btn-xs" onclick="admAction('${p.reg}','rejected')">Отхвърли</button><button class="btn btn-rd btn-xs" onclick="admDel('${p.reg}')">🗑</button>`)).join(''):`<div style="font-size:12px;color:var(--mu);padding:6px">Няма.</div>`;
  document.getElementById('admRejected').innerHTML=rej.length?rej.map(p=>mk(p,`<button class="btn btn-gr btn-xs" onclick="admAction('${p.reg}','approved')">↩ Одобри</button><button class="btn btn-rd btn-xs" onclick="admDel('${p.reg}')">🗑</button>`)).join(''):`<div style="font-size:12px;color:var(--mu);padding:6px">Няма.</div>`;

  // Commission list
  await renderAdmComm();
  await checkAdmDot();
}

async function renderAdmComm(){
  const keys=await stList('comm:');
  const all=[];for(const k of keys){const c=await stGet(k);if(c)all.push(c);}
  all.sort((a,b)=>new Date(b.createdAt)-new Date(a.createdAt));
  const totalPaid=all.filter(c=>c.status==='paid').reduce((s,c)=>s+parseFloat(c.comm),0);
  const totalPend=all.filter(c=>c.status!=='paid').reduce((s,c)=>s+parseFloat(c.comm),0);
  document.getElementById('admCommPaid').textContent=totalPaid.toFixed(2)+'€';
  document.getElementById('admCommPend').textContent=totalPend.toFixed(2)+'€';
  document.getElementById('admCommList').innerHTML=all.slice(0,10).map(c=>`
    <div class="comm-item">
      <div style="display:flex;flex-direction:column;gap:1px">
        <span class="comm-plate">${esc(c.reg)}</span>
        <span style="font-size:10px;color:var(--mu)">${esc(c.from?.split(' ')[0]||'')}→${esc(c.to?.split(' ')[0]||'')}</span>
      </div>
      <div style="display:flex;align-items:center;gap:6px">
        <span class="comm-amount">${c.comm}€</span>
        <span class="comm-status ${c.status==='paid'?'cs-paid':'cs-pend'}">${c.status==='paid'?'Платено':'Чака'}</span>
        ${c.status!=='paid'?`<button class="btn btn-gr btn-xs" onclick="markCommPaid('${c.orderId}')">✓</button>`:''}
      </div>
    </div>`).join('');
}

async function markCommPaid(orderId){
  const c=await stGet('comm:'+orderId);if(!c)return;
  c.status='paid';c.paidAt=new Date().toISOString();
  await stSet('comm:'+orderId,c);
  renderAdmComm();
}

async function admAction(reg,status){
  const p=await stGet('profile:'+reg);if(!p)return;
  p.status=status;p.updatedAt=new Date().toISOString();
  if(status==='approved')p.online=false;
  await stSet('profile:'+reg,p);
  renderAdm();renderPass();
}

async function admDel(reg){
  if(!confirm(`Изтрий ${reg}?`))return;
  await stDel('profile:'+reg);renderAdm();renderPass();
}

