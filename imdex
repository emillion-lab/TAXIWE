<!doctype html>
<html lang="bg">
<head>
<meta charset="utf-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1,user-scalable=no"/>
<title>TaxiMatch Sofia</title>
<style>
:root{
  --bg:#080808;--s1:#111;--s2:#181818;--s3:#222;--s4:#2a2a2a;
  --border:#2c2c2c;--border2:#3a3a3a;
  --y:#f5c518;--yd:rgba(245,197,24,.13);--yg:rgba(245,197,24,.22);
  --tx:#f0f0f0;--mu:#777;--mu2:#555;
  --gr:#22c55e;--rd:#ef4444;--bl:#3b82f6;--or:#f97316;--pu:#a855f7;--cy:#06b6d4;
  --rad:10px;--rads:6px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%}
body{background:var(--bg);color:var(--tx);font-family:'Segoe UI',system-ui,sans-serif;display:flex;flex-direction:column;overflow:hidden}

/* TOPBAR */
.topbar{background:#000;border-bottom:3px solid var(--y);height:52px;display:flex;align-items:center;justify-content:space-between;padding:0 14px;flex-shrink:0;z-index:50}
.logo{display:flex;align-items:center;gap:8px;cursor:pointer;user-select:none}
.logo-ico{font-size:24px}
.logo-tx{font-size:17px;font-weight:900;letter-spacing:-.5px}
.logo-tx b{color:var(--y)}
.tabs{display:flex;gap:2px;background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:2px}
.tab{padding:5px 12px;font-size:12px;font-weight:800;border-radius:6px;cursor:pointer;border:none;background:transparent;color:var(--mu);transition:.15s;white-space:nowrap;position:relative}
.tab.on{background:var(--y);color:#000}
.notif-dot{width:7px;height:7px;border-radius:50%;background:var(--rd);position:absolute;top:3px;right:3px;display:none;animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.3}}

/* PAGES */
.page{display:none;flex:1;flex-direction:column;overflow:hidden;min-height:0}
.page.on{display:flex}
.scroll{flex:1;overflow-y:auto;padding:12px 14px 90px;display:flex;flex-direction:column;gap:10px}
.scroll::-webkit-scrollbar{width:3px}
.scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}

/* PAGE HEADER */
.pg-hd{padding:11px 14px 8px;border-bottom:1px solid var(--border);flex-shrink:0}
.pg-title{font-size:18px;font-weight:900;color:var(--y);letter-spacing:-.4px}
.pg-sub{font-size:11px;color:var(--mu);margin-top:1px}

/* FILTER BAR */
.fbar{padding:8px 14px;background:var(--s1);border-bottom:1px solid var(--border);flex-shrink:0;display:flex;flex-direction:column;gap:7px}
.frow{display:flex;gap:5px;flex-wrap:wrap;align-items:center}
.flbl{font-size:10px;font-weight:800;color:var(--mu);text-transform:uppercase;letter-spacing:.4px;white-space:nowrap}
.chip{background:var(--s3);border:1px solid var(--border);border-radius:20px;padding:5px 10px;font-size:11px;font-weight:700;cursor:pointer;color:var(--mu);transition:.12s;white-space:nowrap;user-select:none}
.chip:hover{border-color:var(--border2)}
.chip.on{border-color:var(--y);color:var(--y);background:var(--yd)}
select.fsel{background:var(--s3);border:1px solid var(--border);border-radius:20px;padding:4px 10px;font-size:11px;font-weight:700;color:var(--tx);cursor:pointer;outline:none;max-width:160px}
select.fsel:focus{border-color:var(--y)}

/* DRIVER CARDS */
.dcard{background:var(--s2);border:1px solid var(--border);border-radius:var(--rad);padding:13px;cursor:pointer;transition:.12s;position:relative;overflow:hidden}
.dcard:hover{border-color:var(--yg);background:var(--s3)}
.dcard::before{content:'';position:absolute;left:0;top:0;bottom:0;width:4px;background:var(--border2)}
.dcard.is-online::before{background:var(--gr)}
.dc-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px;margin-bottom:9px}
.plate{font-family:monospace;font-weight:900;background:var(--y);color:#000;padding:3px 8px;border-radius:5px;letter-spacing:.8px;white-space:nowrap;font-size:16px}
.plate.sm{font-size:13px;padding:2px 6px}
.dc-meta{display:flex;flex-direction:column;gap:2px;flex:1;min-width:0}
.dc-op{font-size:10px;color:var(--mu);font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.dc-car{font-size:11px;color:var(--mu2)}
.spill{font-size:10px;font-weight:800;padding:2px 8px;border-radius:10px;white-space:nowrap;flex-shrink:0}
.sp-on{background:rgba(34,197,94,.12);color:var(--gr);border:1px solid rgba(34,197,94,.3)}
.sp-off{background:rgba(119,119,119,.08);color:var(--mu);border:1px solid var(--border)}
.sp-pend{background:rgba(245,197,24,.12);color:var(--y);border:1px solid rgba(245,197,24,.3)}
.sp-rej{background:rgba(239,68,68,.1);color:var(--rd);border:1px solid rgba(239,68,68,.25)}
.tags{display:flex;flex-wrap:wrap;gap:4px;margin-bottom:7px}
.tag{font-size:10px;font-weight:700;padding:2px 7px;border-radius:5px;border:1px solid}
.ty{background:var(--yd);color:var(--y);border-color:rgba(245,197,24,.3)}
.tg{background:rgba(34,197,94,.08);color:var(--gr);border-color:rgba(34,197,94,.25)}
.tb{background:rgba(59,130,246,.08);color:var(--bl);border-color:rgba(59,130,246,.25)}
.to{background:rgba(249,115,22,.08);color:var(--or);border-color:rgba(249,115,22,.25)}
.tp{background:rgba(168,85,247,.08);color:var(--pu);border-color:rgba(168,85,247,.25)}
.tmu{background:rgba(119,119,119,.06);color:var(--mu);border-color:var(--border)}
.tc{background:rgba(6,182,212,.08);color:var(--cy);border-color:rgba(6,182,212,.25)}
.bio{font-size:12px;color:#bbb;line-height:1.5;margin-bottom:6px}
.dc-ft{display:flex;justify-content:space-between;align-items:center;font-size:10px;color:var(--mu);margin-top:4px}
.dc-hrs{color:var(--mu)}
.dc-dst{color:var(--y);font-weight:700}
.dc-carinfo{font-size:11px;color:var(--cy);font-weight:600;margin-bottom:5px}

/* ORDER BUTTON on card */
.order-btn-card{position:absolute;bottom:12px;right:12px;background:var(--y);color:#000;border:none;border-radius:var(--rads);padding:6px 12px;font-size:12px;font-weight:900;cursor:pointer;transition:.12s}
.order-btn-card:hover{background:#ffd700}

/* EMPTY / LOADING */
.empty{text-align:center;padding:50px 20px;color:var(--mu)}
.empty-ico{font-size:44px;margin-bottom:10px}
.empty-msg{font-size:13px;font-weight:600;line-height:1.6}
.spin{display:inline-block;width:16px;height:16px;border:2px solid rgba(245,197,24,.2);border-top-color:var(--y);border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle;margin-right:6px}
@keyframes spin{to{transform:rotate(360deg)}}
.loading{display:flex;align-items:center;justify-content:center;padding:30px;color:var(--mu);font-size:13px;font-weight:600}

/* FORM ELEMENTS */
.fsec{background:var(--s2);border:1px solid var(--border);border-radius:var(--rad);padding:13px;display:flex;flex-direction:column;gap:10px}
.fsec-title{font-size:11px;font-weight:900;color:var(--y);text-transform:uppercase;letter-spacing:.5px}
.frow2{display:flex;flex-direction:column;gap:3px}
.flabel{font-size:10px;color:var(--mu);font-weight:700;text-transform:uppercase;letter-spacing:.3px}
.finput{background:var(--s1);border:1px solid var(--border);border-radius:var(--rads);padding:9px 11px;color:var(--tx);font-size:14px;outline:none;width:100%;font-family:inherit;transition:.12s}
.finput:focus{border-color:var(--y)}
.finput.mono{font-family:monospace;font-size:20px;font-weight:900;text-transform:uppercase;letter-spacing:2px;text-align:center}
textarea.finput{resize:vertical;min-height:65px;font-size:13px}
.chips2{display:flex;gap:5px;flex-wrap:wrap;margin-top:2px}
.pc{background:var(--s1);border:1px solid var(--border);border-radius:18px;padding:5px 11px;font-size:11px;font-weight:700;cursor:pointer;color:var(--mu);transition:.12s;user-select:none}
.pc.on{border-color:var(--y);color:var(--y);background:var(--yd)}
.pc:hover:not(.on){border-color:var(--border2)}
.grid3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:4px}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:5px}
.gc{background:var(--s1);border:1px solid var(--border);border-radius:var(--rads);padding:6px 4px;font-size:10px;font-weight:700;text-align:center;cursor:pointer;color:var(--mu);transition:.12s;user-select:none;line-height:1.3}
.gc.on{border-color:var(--y);color:var(--y);background:var(--yd)}
.tog-row{display:flex;justify-content:space-between;align-items:center}
.tog-lbl{font-size:13px;font-weight:700}
.tog{width:42px;height:23px;background:var(--border2);border-radius:12px;cursor:pointer;position:relative;transition:.2s;border:none;flex-shrink:0}
.tog.on{background:var(--y)}
.tog::after{content:'';position:absolute;width:17px;height:17px;border-radius:50%;background:#fff;top:3px;left:3px;transition:.2s}
.tog.on::after{left:22px;background:#000}

/* BUTTONS */
.btn{display:block;width:100%;padding:12px;border-radius:var(--rad);font-size:14px;font-weight:900;cursor:pointer;border:none;transition:.15s;text-align:center}
.btn-y{background:var(--y);color:#000}
.btn-y:hover{background:#ffd700}
.btn-y:active{background:#e6b800}
.btn-ghost{background:var(--s2);border:1px solid var(--border);color:var(--tx)}
.btn-ghost:hover{border-color:var(--y);color:var(--y)}
.btn-rd{background:rgba(239,68,68,.1);border:1px solid rgba(239,68,68,.3);color:var(--rd)}
.btn-gr{background:rgba(34,197,94,.1);border:1px solid rgba(34,197,94,.3);color:var(--gr)}
.btn-bl{background:rgba(59,130,246,.1);border:1px solid rgba(59,130,246,.3);color:var(--bl)}
.btn-sm{padding:6px 13px;font-size:12px;width:auto;border-radius:var(--rads)}
.btn-xs{padding:4px 9px;font-size:11px;width:auto;border-radius:5px}

/* VERIFY BOX */
.vbox{background:var(--s2);border:2px dashed var(--border2);border-radius:var(--rad);padding:20px 16px;text-align:center;display:flex;flex-direction:column;align-items:center;gap:11px}
.vbox.ok{border:2px solid var(--gr);background:rgba(34,197,94,.03)}
.vbox-ico{font-size:36px}
.vbox-title{font-size:16px;font-weight:900;color:var(--y)}
.vbox-sub{font-size:12px;color:var(--mu);line-height:1.5}
.vr{width:100%;padding:9px 13px;border-radius:var(--rads);font-size:12px;font-weight:700;text-align:center}
.vr-ok{background:rgba(34,197,94,.1);color:var(--gr);border:1px solid rgba(34,197,94,.3)}
.vr-err{background:rgba(239,68,68,.1);color:var(--rd);border:1px solid rgba(239,68,68,.3)}
.vr-pend{background:rgba(245,197,24,.1);color:var(--y);border:1px solid rgba(245,197,24,.3)}

/* NOTICE */
.notice{padding:10px 13px;border-radius:var(--rads);font-size:12px;font-weight:600;line-height:1.5}
.n-ok{background:rgba(34,197,94,.08);color:var(--gr);border:1px solid rgba(34,197,94,.2)}
.n-warn{background:rgba(245,197,24,.08);color:var(--y);border:1px solid rgba(245,197,24,.2)}
.n-err{background:rgba(239,68,68,.08);color:var(--rd);border:1px solid rgba(239,68,68,.2)}
.n-info{background:rgba(59,130,246,.08);color:var(--bl);border:1px solid rgba(59,130,246,.2)}
.n-pu{background:rgba(168,85,247,.08);color:var(--pu);border:1px solid rgba(168,85,247,.2)}

/* MODAL / OVERLAY */
.overlay{position:fixed;inset:0;background:rgba(0,0,0,.9);z-index:200;display:flex;align-items:flex-end;justify-content:center;padding:10px}
.overlay.hide{display:none}
.modal{background:var(--s2);border:1px solid var(--border2);border-radius:14px;padding:16px;width:100%;max-width:520px;max-height:93vh;overflow-y:auto;display:flex;flex-direction:column;gap:12px}
.modal::-webkit-scrollbar{width:3px}
.modal::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.modal-title{font-size:17px;font-weight:900;color:var(--y)}
.mrow{display:flex;flex-direction:column;gap:4px}
.mlbl{font-size:10px;color:var(--mu);font-weight:700;text-transform:uppercase;letter-spacing:.3px}
.mval{font-size:13px;font-weight:600;line-height:1.5}

/* ORDER FLOW inside modal */
.order-step{display:flex;flex-direction:column;gap:10px}
.price-calc{background:var(--s1);border:1px solid var(--y);border-radius:var(--rad);padding:13px;display:flex;flex-direction:column;gap:7px}
.price-row{display:flex;justify-content:space-between;align-items:center;font-size:13px}
.price-row .lbl{color:var(--mu)}
.price-row .val{font-weight:900;color:var(--tx)}
.price-row.total .val{font-size:18px;color:var(--y)}
.price-row.commission .val{color:var(--gr);font-size:12px}
.divider{border:none;border-top:1px solid var(--border);margin:2px 0}
.revolut-btn{display:flex;align-items:center;justify-content:center;gap:8px;background:linear-gradient(135deg,#191c4a,#2c2fd4);border:none;border-radius:var(--rad);padding:14px;font-size:15px;font-weight:900;color:#fff;cursor:pointer;transition:.15s;text-decoration:none;width:100%}
.revolut-btn:hover{opacity:.9}
.revolut-btn .rev-ico{font-size:20px}
.booking-opts{display:grid;grid-template-columns:repeat(3,1fr);gap:6px}
.book-opt{background:var(--s1);border:1px solid var(--border);border-radius:var(--rads);padding:8px 4px;text-align:center;cursor:pointer;transition:.12s}
.book-opt:hover{border-color:var(--border2)}
.book-opt.on{border-color:var(--y);background:var(--yd)}
.book-opt .bo-price{font-size:15px;font-weight:900;color:var(--y)}
.book-opt.on .bo-price{color:var(--y)}
.book-opt .bo-label{font-size:10px;color:var(--mu);font-weight:600;margin-top:2px}

/* REQUESTS (driver side) */
.req-card{background:var(--s2);border:1px solid var(--border);border-radius:var(--rad);padding:12px;display:flex;flex-direction:column;gap:8px}
.req-card.new-req{border-color:rgba(245,197,24,.4);background:rgba(245,197,24,.03)}
.req-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
.req-from{font-size:13px;font-weight:700}
.req-detail{font-size:11px;color:var(--mu)}
.req-actions{display:flex;gap:6px;flex-wrap:wrap}

/* ADMIN */
.adm-card{background:var(--s2);border:1px solid var(--border);border-radius:var(--rad);padding:12px;display:flex;flex-direction:column;gap:8px;margin-bottom:8px}
.adm-card.pend{border-color:rgba(245,197,24,.35)}
.adm-card.approved{border-color:rgba(34,197,94,.25)}
.adm-card.rejected{border-color:rgba(239,68,68,.2);opacity:.65}
.adm-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
.adm-info{flex:1;min-width:0;display:flex;flex-direction:column;gap:3px}
.adm-name{font-size:13px;font-weight:700}
.adm-det{font-size:11px;color:var(--mu)}
.adm-actions{display:flex;gap:5px;flex-wrap:wrap}
.stat-box{background:var(--s2);border:1px solid var(--border);border-radius:var(--rad);padding:10px;text-align:center}
.stat-val{font-size:22px;font-weight:900}
.stat-lbl{font-size:10px;color:var(--mu);font-weight:700;margin-top:2px}

/* COMMISSION TRACKER */
.comm-item{display:flex;justify-content:space-between;align-items:center;padding:8px 10px;background:var(--s1);border-radius:var(--rads);border:1px solid var(--border);font-size:12px}
.comm-plate{font-family:monospace;font-weight:900;color:var(--y)}
.comm-amount{font-weight:900;color:var(--gr)}
.comm-status{font-size:10px;font-weight:700;padding:2px 7px;border-radius:8px}
.cs-paid{background:rgba(34,197,94,.12);color:var(--gr);border:1px solid rgba(34,197,94,.25)}
.cs-pend{background:rgba(245,197,24,.1);color:var(--y);border:1px solid rgba(245,197,24,.25)}
</style>
</head>
<body>

<div class="topbar">
  <div class="logo" onclick="logoTap()">
    <div class="logo-ico">🚕</div>
    <div class="logo-tx">Taxi<b>Match</b></div>
  </div>
  <div class="tabs">
    <button class="tab on" id="tPass" onclick="goPage('pass')">🔍 Намери</button>
    <button class="tab" id="tDrv" onclick="goPage('drv')">🚕 Шофьор</button>
    <button class="tab" id="tAdm" onclick="goPage('adm')">⚙️<span class="notif-dot" id="admDot"></span></button>
  </div>
</div>

<!-- ══ PASSENGER PAGE ══ -->
<div class="page on" id="pagePass">
  <div class="pg-hd">
    <div class="pg-title">Намери такси</div>
    <div class="pg-sub">Само верифицирани шофьори от официалния регистър на ИААА</div>
  </div>
  <div class="fbar">
    <div class="frow">
      <span class="flbl">Комфорт:</span>
      <div class="chip" data-f="smoke" onclick="tF(this)">🚬 Пушене</div>
      <div class="chip" data-f="alcohol" onclick="tF(this)">🍺 Алкохол</div>
      <div class="chip" data-f="pet" onclick="tF(this)">🐾 Животни</div>
      <div class="chip" data-f="child" onclick="tF(this)">👶 Детско</div>
      <div class="chip" data-f="card" onclick="tF(this)">💳 Карта</div>
      <div class="chip" data-f="english" onclick="tF(this)">🇬🇧 EN</div>
    </div>
    <div class="frow">
      <span class="flbl">Кола:</span>
      <div class="chip" data-f="comfort" onclick="tF(this)">🛋 Комфорт</div>
      <div class="chip" data-f="legroom" onclick="tF(this)">🦵 Място за крака</div>
      <div class="chip" data-f="boot_big" onclick="tF(this)">🧳 Голям багаж</div>
      <div class="chip" data-f="van" onclick="tF(this)">🚐 Ван</div>
    </div>
    <div class="frow">
      <span class="flbl">Марка:</span>
      <select class="fsel" id="brandFlt" onchange="renderPass()">
        <option value="">Всички</option>
      </select>
      <span class="flbl" style="margin-left:4px">Район:</span>
      <select class="fsel" id="distFlt" onchange="renderPass()">
        <option value="">Всички</option>
      </select>
      <div class="chip" data-f="online_now" onclick="tF(this)">🟢 Онлайн</div>
    </div>
  </div>
  <div class="scroll" id="passScroll">
    <div class="loading" id="passLoad"><div class="spin"></div>Зареждане…</div>
  </div>
</div>

<!-- ══ DRIVER PAGE ══ -->
<div class="page" id="pageDrv">
  <div class="scroll" id="drvScroll" style="padding-top:14px">

    <!-- Step 1: verify -->
    <div id="drvS1">
      <div class="vbox" id="vbox">
        <div class="vbox-ico">🪪</div>
        <div class="vbox-title">Регистрация на шофьор</div>
        <div class="vbox-sub">Въведи рег. номер на таксито — ще се провери срещу официалния регистър на ИААА. Молбата отива за одобрение от администратора.</div>
        <input class="finput mono" id="vPlate" placeholder="СО1234АВ" maxlength="12"
          oninput="this.value=this.value.toUpperCase().replace(/[^А-ЯA-Z0-9]/g,'')"/>
        <div class="frow2" style="width:100%;text-align:left">
          <div class="flabel">Телефон (Viber) за контакт с администратора</div>
          <input class="finput" id="vPhone" placeholder="+359 8X XXX XXXX" type="tel"/>
        </div>
        <div id="vResult" style="display:none;width:100%"></div>
        <button class="btn btn-y" id="vBtn" onclick="doVerify()">Провери и изпрати молба →</button>
      </div>
    </div>

    <!-- Step 2: pending -->
    <div id="drvS2" style="display:none">
      <div class="vbox">
        <div class="vbox-ico">⏳</div>
        <div class="vbox-title">Молбата е изпратена!</div>
        <div id="pendingMsg" class="vbox-sub"></div>
        <div class="notice n-warn">📱 Изпрати снимка на таксиметровото разрешително по Viber за потвърждение на самоличността.</div>
        <button class="btn btn-ghost btn-sm" onclick="drvLogout()">← Назад</button>
      </div>
    </div>

    <!-- Step 3: profile editor -->
    <div id="drvS3" style="display:none;flex-direction:column;gap:12px">

      <div class="vbox ok" style="padding:13px">
        <div style="font-size:26px">✅</div>
        <div class="vbox-title" id="drvBadgeTitle"></div>
        <div style="font-size:11px;color:var(--mu)" id="drvBadgeSub"></div>
      </div>

      <!-- Incoming requests -->
      <div id="drvRequestsSection" style="display:none">
        <div style="font-size:12px;font-weight:900;color:var(--y);text-transform:uppercase;letter-spacing:.4px;margin-bottom:7px">📨 Нови поръчки</div>
        <div id="drvRequests"></div>
      </div>

      <!-- Commission tracker -->
      <div class="fsec" id="drvCommSection" style="display:none">
