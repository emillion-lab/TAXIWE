async function stGet(k){try{const r=await window.storage.get(k);return r?JSON.parse(r.value):null;}catch{return null;}}
async function stSet(k,v){try{await window.storage.set(k,JSON.stringify(v));return true;}catch(e){console.error(e);return false;}}
async function stDel(k){try{await window.storage.delete(k);return true;}catch{return false;}}
async function stList(pre){try{const r=await window.storage.list(pre);return r?.keys||[];}catch{return[];}}

