async function renderPass(){
  const scroll=document.getElementById('passScroll');
  const keys=await stList('profile:');
  const brand=document.getElementById('brandFlt').value;
  const dist=document.getElementById('distFlt').value;
  const profiles=[];
  for(const k of keys){const p=await stGet(k);if(p&&p.status==='approved')profiles.push(p);}

  let vis=profiles.filter(p=>{
    const pr=p.prefs||[];
    if(activeF.has('online_now')&&!p.online)return false;
    if(activeF.has('smoke')&&!pr.includes('smoke_yes')&&!pr.includes('smoke_pause'))return false;
    if(activeF.has('alcohol')&&!pr.includes('alc_yes'))return false;
    if(activeF.has('pet')&&!pr.includes('pet_yes'))return false;
    if(activeF.has('child')&&!pr.includes('child'))return false;
    if(activeF.has('card')&&!pr.includes('card'))return false;
    if(activeF.has('english')&&!pr.includes('english'))return false;
    if(activeF.has('comfort')&&!pr.includes('comfort'))return false;
    if(activeF.has('legroom')&&!pr.includes('legroom'))return false;
    if(activeF.has('boot_big')&&!pr.includes('boot_l')&&!pr.includes('boot_xl'))return false;
    if(activeF.has('van')&&!pr.includes('size_l'))return false;
    if(brand&&p.carBrand!==brand)return false;
    if(dist&&!(p.districts||[]).includes(dist))return false;
    return true;
  });

  vis.sort((a,b)=>(b.online?1:0)-(a.online?1:0)||(new Date(b.updatedAt||0)-new Date(a.updatedAt||0)));

  if(!vis.length){
    scroll.innerHTML=`<div class="empty"><div class="empty-ico">🚕</div><div class="empty-msg">${profiles.length?'Няма шофьори с тези критерии.<br>Промени филтрите.':'Все още няма одобрени шофьори.'}</div></div>`;
    return;
  }

  scroll.innerHTML=vis.map(p=>{
    const pr=p.prefs||[];
    const showTags=pr.filter(k=>PTAGS[k]&&!['tip2','tip5','tip10','book2','book5','book10'].includes(k)).slice(0,5);
    const tags=showTags.map(k=>`<span class="tag ${PTAGS[k].c}">${PTAGS[k].l}</span>`).join('');
    const hrs=(p.hours||[]).join(' · ');
    const dst=(p.districts||[]).slice(0,3).join(', ')+((p.districts||[]).length>3?'…':'');
    const carInfo=[p.carBrand,p.carModel,p.carYear].filter(Boolean).join(' ');
    return `<div class="dcard ${p.online?'is-online':''}" onclick="openModal('${p.reg}')">
      <div class="dc-top">
        <div class="dc-meta">
          <div class="plate sm">${esc(p.reg)}</div>
          <div class="dc-op">${esc(p.op||'')}</div>
          ${carInfo?`<div class="dc-car">🚗 ${esc(carInfo)}</div>`:''}
        </div>
        <span class="spill ${p.online?'sp-on':'sp-off'}">${p.online?'🟢 Онлайн':'Офлайн'}</span>
      </div>
      ${p.carComfort?`<div class="dc-carinfo">💺 ${esc(p.carComfort)}</div>`:''}
      ${tags?`<div class="tags">${tags}</div>`:''}
      ${p.bio?`<div class="bio">${esc(p.bio)}</div>`:''}
      <div class="dc-ft">
        <span class="dc-hrs">${hrs?'🕐 '+hrs:''}</span>
        <span class="dc-dst">${dst?'📍 '+dst:''}</span>
      </div>
      <button class="order-btn-card" onclick="event.stopPropagation();openModal('${p.reg}',true)">🚕 Поръчай</button>
    </div>`;
  }).join('');
}

